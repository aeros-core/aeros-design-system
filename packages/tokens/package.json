{
  "name": "@aeros-core/tokens",
  "version": "1.0.0",
  "description": "Aeros design tokens — source of truth.",
  "type": "module",
  "main": "./dist/js/tokens.js",
  "types": "./dist/js/tokens.d.ts",
  "exports": {
    ".": {
      "types": "./dist/js/tokens.d.ts",
      "import": "./dist/js/tokens.js"
    },
    "./css": "./dist/css/tokens.css",
    "./tailwind": {
      "types": "./dist/tailwind/preset.d.ts",
      "import": "./dist/tailwind/preset.js"
    },
    "./dart": "./dist/dart/aeros_tokens.dart",
    "./source": "./src/tokens.json"
  },
  "files": ["dist", "src"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aeros-core/aeros-design-system.git",
    "directory": "packages/tokens"
  },
  "scripts": {
    "build": "tsx src/build.ts",
    "dev": "tsx watch src/build.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
