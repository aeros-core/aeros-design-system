{
  "name": "aeros-design-system",
  "private": true,
  "version": "1.0.0",
  "description": "Aeros Design System — tokens, React components, and Flutter widgets.",
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "build": "pnpm -r build",
    "build:tokens": "pnpm --filter @aeros-core/tokens build",
    "build:react": "pnpm --filter @aeros-core/react build",
    "dev": "pnpm -r --parallel dev",
    "check:contrast": "node scripts/check-contrast.mjs",
    "clean": "pnpm -r exec rm -rf dist",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:tokens && pnpm build:react && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
